# Configuration for LLM Pipeline

# Which LLM provider to use
# Options: "mock" (testing), "openai", "ollama"
LLM_PROVIDER=mock

# Model name
# For OpenAI: gpt-4, gpt-3.5-turbo
# For Ollama: llama2, neural-chat, mistral, etc.
LLM_MODEL=llama2

# OpenAI API key (if using OpenAI provider)
OPENAI_API_KEY=

# Ollama settings (if using Ollama provider)
OLLAMA_BASE_URL=http://localhost:11434

# FastAPI server settings
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Safety settings
ENABLE_SAFETY_CHECKS=true
BLOCK_MEDICATION_MENTION=true
REQUIRE_BILINGUAL_OUTPUT=true
